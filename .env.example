# Google Apps Script Web App URL for Google Sheets Integration
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/your_script_id/exec

# Email Configuration (using Gmail or custom SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@startupconnect.com
ADMIN_EMAIL=hello@thehalfbrick.com

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Resend Email Service
RESEND_API_KEY=your-resend-api-key
